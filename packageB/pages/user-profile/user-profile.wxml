<view class="profile-container">
  <view class="header-card">
    <view class="header-title">个人信息</view>
    <view class="header-sub">完善资料可获得更精准的房源推荐</view>
  </view>

  <view class="card">
    <view class="group-title">基本资料</view>
    <view class="row"><text class="lab">用户名</text><input class="ipt" value="{{form.username}}" data-field="username" bindinput="onInput" /></view>
    <view class="row"><text class="lab">真实姓名</text><input class="ipt" value="{{form.realName}}" data-field="realName" bindinput="onInput" /></view>
    <view class="row"><text class="lab">手机号</text><input class="ipt" type="number" maxlength="11" value="{{form.phone}}" data-field="phone" bindinput="onInput" /></view>
    <view class="row"><text class="lab">邮箱</text><input class="ipt" value="{{form.email}}" data-field="email" bindinput="onInput" /></view>
    <view class="row"><text class="lab">公司/学校</text><input class="ipt" value="{{form.company}}" data-field="company" bindinput="onInput" /></view>
    <view class="row"><text class="lab">微信号</text><input class="ipt" value="{{form.wechat}}" data-field="wechat" bindinput="onInput" /></view>
    <view class="row"><text class="lab">QQ</text><input class="ipt" value="{{form.qq}}" data-field="qq" bindinput="onInput" /></view>
    <view class="row"><text class="lab">职业</text><input class="ipt" value="{{form.job}}" data-field="job" bindinput="onInput" /></view>
  </view>

  <view class="card">
    <view class="group-title">租房偏好</view>
    <view class="row"><text class="lab">最低预算</text><input class="ipt" type="number" value="{{form.rentalBudgetMin}}" data-field="rentalBudgetMin" bindinput="onInput" /></view>
    <view class="row"><text class="lab">最高预算</text><input class="ipt" type="number" value="{{form.rentalBudgetMax}}" data-field="rentalBudgetMax" bindinput="onInput" /></view>
    <view class="row"><text class="lab">偏好区域</text><input class="ipt" value="{{form.preferredDistricts}}" data-field="preferredDistricts" bindinput="onInput" /></view>
    <view class="row full">
      <text class="lab">租房需求</text>
      <textarea class="ta" value="{{form.houseRequirements}}" data-field="houseRequirements" bindinput="onInput" placeholder="例如：近地铁、可养宠物、预算3000内" />
    </view>
  </view>

  <button class="save-btn hs-btn-primary" bindtap="onSave" loading="{{saving}}">保存信息</button>
</view>