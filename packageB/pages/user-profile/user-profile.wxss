.profile-container {
  min-height: 100vh;
  background: #f0fdfa;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.header-card {
  border-radius: 24rpx;
  padding: 22rpx 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  box-shadow: 0 12rpx 30rpx rgba(13, 148, 136, 0.26);
}

.header-title {
  font-size: 34rpx;
  font-weight: 800;
}

.header-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.92;
}

.card {
  margin-top: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
}

.group-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #334155;
  margin-bottom: 10rpx;
}

.row {
  margin-top: 10rpx;
}

.row.full .ta {
  margin-top: 8rpx;
}

.lab {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 8rpx;
  font-weight: 700;
}

.ipt {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
  font-size: 27rpx;
  color: #111827;
  box-sizing: border-box;
}

.ta {
  width: 100%;
  min-height: 150rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
  padding: 16rpx;
  font-size: 26rpx;
  color: #111827;
  box-sizing: border-box;
}

.save-btn {
  margin-top: 22rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}