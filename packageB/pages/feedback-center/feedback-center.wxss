.page { min-height: 100vh; background: #f0fdfa; padding: 24rpx; box-sizing: border-box; }
.card { background: #fff; border-radius: 24rpx; padding: 24rpx; }
.title { font-size: 32rpx; font-weight: 800; color: #0f172a; margin-bottom: 14rpx; }
.chips { display: flex; gap: 10rpx; margin-bottom: 12rpx; }
.chip { padding: 8rpx 18rpx; border-radius: 999rpx; background: #f1f5f9; color: #334155; font-size: 23rpx; }
.chip.active { background: #0d9488; color: #fff; }
.ta { width: 100%; min-height: 180rpx; border: 1rpx solid #e2e8f0; background: #f8fafc; border-radius: 14rpx; padding: 16rpx; box-sizing: border-box; }
.ipt { margin-top: 12rpx; width: 100%; height: 82rpx; line-height: 82rpx; padding: 0 18rpx; border-radius: 14rpx; border: 1rpx solid #e2e8f0; background: #f8fafc; font-size: 26rpx; box-sizing: border-box; }
.btn { margin-top: 16rpx; height: 84rpx; line-height: 84rpx; font-size: 30rpx; }
