<view class="page">
  <view class="card">
    <view class="title">宽带信息</view>
    <view wx:if="{{!wifi && !loading}}" class="empty">暂无可用 WiFi 信息</view>
    <view wx:if="{{wifi}}">
      <view class="row">
        <text class="k">名称</text>
        <text class="v">{{wifi.ssid}}</text>
      </view>
      <view class="row">
        <text class="k">密码</text>
        <text class="v">{{wifi.password}}</text>
      </view>
      <view class="row">
        <text class="k">频段</text>
        <text class="v">{{wifi.band}}</text>
      </view>
      <view class="row">
        <text class="k">覆盖位置</text>
        <text class="v">{{wifi.roomName}}</text>
      </view>
      <button class="copy-btn" data-value="{{wifi.password}}" bindtap="copyValue">复制密码</button>
    </view>
  </view>
</view>
