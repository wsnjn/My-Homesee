.chat-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding-bottom: 110rpx;
  box-sizing: border-box;
}

.msg-list {
  height: calc(100vh - 110rpx);
  padding: 20rpx;
  box-sizing: border-box;
}

.empty {
  margin-top: 220rpx;
  text-align: center;
  color: #98a0ad;
  font-size: 28rpx;
}

.msg-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.msg-row.self {
  align-items: flex-end;
}

.bubble {
  max-width: 72%;
  background: #fff;
  color: #1c212b;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
}

.msg-row.self .bubble {
  background: #1b86ff;
  color: #fff;
}

.time {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #a0a7b3;
}

.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 1rpx solid #eceff3;
  display: flex;
  align-items: center;
  padding: 14rpx 16rpx calc(env(safe-area-inset-bottom) + 14rpx);
  box-sizing: border-box;
}

.input {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  background: #f1f4f9;
  padding: 0 22rpx;
  font-size: 28rpx;
}

.send {
  margin-left: 12rpx;
  width: 118rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: #1b86ff;
  color: #fff;
  font-size: 28rpx;
}