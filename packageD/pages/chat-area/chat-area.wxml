<view class="chat-page">
  <scroll-view class="msg-list" scroll-y scroll-into-view="{{scrollTo}}">
    <view wx:if="{{messages.length === 0 && !loading}}" class="empty">暂无消息，开始聊聊吧</view>
    <view
      wx:for="{{messages}}"
      wx:key="id"
      id="msg-{{item.id}}"
      class="msg-row {{item.isSelf ? 'self' : ''}}"
    >
      <view class="bubble">{{item.content}}</view>
      <text class="time">{{item.timeText}}</text>
    </view>
  </scroll-view>

  <view class="input-bar">
    <input
      class="input"
      placeholder="输入消息..."
      value="{{inputText}}"
      bindinput="onInput"
      bindconfirm="sendMessage"
      confirm-type="send"
    />
    <button class="send" bindtap="sendMessage">发送</button>
  </view>
</view>