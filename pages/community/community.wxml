<view class="message-page">
  <view class="msg-header">
    <view class="header-row">
      <view class="header-titles">
        <text class="title">消息</text>
        <text class="subtitle">会话 · 邻里动态</text>
      </view>
      <view wx:if="{{unreadTotal > 0}}" class="badge-pill">{{unreadTotal}} 条未读</view>
      <view wx:else class="status-pill">已全部已读</view>
    </view>
  </view>

  <view class="social-entries">
    <view class="social-card" hover-class="social-card-hover" bindtap="goFriendCircle">
      <view class="social-card-ico">
        <svg-icon name="users" size="40" color="#0d9488" />
      </view>
      <view class="social-card-text">
        <text class="social-card-title">朋友圈</text>
        <text class="social-card-desc">发动态、点赞与评论</text>
      </view>
      <text class="social-card-arrow">›</text>
    </view>
  </view>

  <scroll-view class="msg-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{conversations.length === 0}}" class="empty-wrap">
      <view class="empty-card">
        <view class="empty-ico">
          <svg-icon name="message" size="56" color="#cbd5e1" />
        </view>
        <text class="empty-main">还没有消息</text>
        <text class="empty-sub">去看房后可与房东发起沟通，预约也会提醒到这里</text>
        <button class="empty-btn hs-btn-primary" bindtap="goHouseSelection">去看房</button>
      </view>
    </view>

    <view
      wx:for="{{conversations}}"
      wx:key="id"
      class="msg-card"
      hover-class="msg-card-hover"
      data-item="{{item}}"
      bindtap="openChat"
    >
      <view class="avatar-frame">
        <image class="avatar" src="{{item.avatar}}" mode="aspectFill" />
      </view>
      <view class="main">
        <view class="row top">
          <text class="name">{{item.title}}</text>
          <text class="time">{{item.lastTime}}</text>
        </view>
        <view class="row bottom">
          <text class="preview">{{item.lastText}}</text>
          <view class="unread-dot" wx:if="{{item.unread > 0}}">{{item.unread}}</view>
        </view>
      </view>
    </view>
    <view class="list-pad"></view>
  </scroll-view>
</view>
