<view class="message-page">
  <view class="top-bar">
    <text class="title">消息</text>
    <view class="badge" wx:if="{{unreadTotal > 0}}">{{unreadTotal}}</view>
  </view>

  <scroll-view class="msg-list" scroll-y>
    <view wx:if="{{conversations.length === 0}}" class="empty">
      <text class="empty-main">暂无消息</text>
      <text class="empty-sub">去看房后可与房东发起沟通</text>
      <button class="go-btn" bindtap="goHouseSelection">去看房</button>
    </view>

    <view
      wx:for="{{conversations}}"
      wx:key="id"
      class="msg-item"
      data-item="{{item}}"
      bindtap="openChat"
    >
      <image class="avatar" src="{{item.avatar}}" mode="aspectFill" />
      <view class="main">
        <view class="row">
          <text class="name">{{item.title}}</text>
          <text class="time">{{item.lastTime}}</text>
        </view>
        <view class="row">
          <text class="preview">{{item.lastText}}</text>
          <view class="dot" wx:if="{{item.unread > 0}}">{{item.unread}}</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>