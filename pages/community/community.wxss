.message-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0fdfa 0%, #ecfeff 40%, #f8fafc 100%);
}

.msg-header {
  padding: 28rpx 28rpx 20rpx;
  background: linear-gradient(180deg, rgba(15, 118, 110, 0.12) 0%, transparent 100%);
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.header-titles {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #0f172a;
}

.subtitle {
  font-size: 24rpx;
  color: #64748b;
}

.social-entries {
  padding: 0 24rpx 16rpx;
}

.social-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  border: 1rpx solid rgba(13, 148, 136, 0.2);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.social-card-hover {
  opacity: 0.92;
}

.social-card-ico {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.social-card-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.social-card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}

.social-card-desc {
  font-size: 24rpx;
  color: #64748b;
}

.social-card-arrow {
  font-size: 44rpx;
  color: #cbd5e1;
  font-weight: 300;
  line-height: 1;
}

.badge-pill {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f97316, #fb923c);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(249, 115, 22, 0.35);
}

.status-pill {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(13, 148, 136, 0.2);
  color: #0d9488;
  font-size: 22rpx;
  font-weight: 600;
}

.msg-list {
  height: calc(100vh - 200rpx - 140rpx);
  padding: 0 24rpx;
  box-sizing: border-box;
}

.empty-wrap {
  padding: 80rpx 0 40rpx;
}

.empty-card {
  text-align: center;
  padding: 56rpx 36rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.06);
}

.empty-ico {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.empty-main {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #334155;
}

.empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.5;
}

.empty-btn {
  margin-top: 32rpx;
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.empty-btn::after {
  border: none;
}

.msg-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  border: 1rpx solid rgba(241, 245, 249, 0.95);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.msg-card-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 18rpx 40rpx rgba(13, 148, 136, 0.12);
}

.avatar-frame {
  width: 100rpx;
  height: 100rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #ccfbf1, #99f6e4);
  padding: 4rpx;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
}

.main {
  flex: 1;
  min-width: 0;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.row.top {
  margin-bottom: 8rpx;
}

.name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  flex-shrink: 0;
  color: #94a3b8;
  font-size: 22rpx;
}

.preview {
  flex: 1;
  min-width: 0;
  color: #64748b;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread-dot {
  flex-shrink: 0;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  text-align: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ef4444, #f97316);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.list-pad {
  height: 40rpx;
}
