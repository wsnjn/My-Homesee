/* 消息页（Tab） */
.message-page {
  min-height: 100vh;
  background: #f7f8fb;
}

.top-bar {
  height: 96rpx;
  background: #fff;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
}

.title {
  font-size: 36rpx;
  color: #111;
  font-weight: 700;
}

.badge {
  margin-left: 12rpx;
  min-width: 36rpx;
  padding: 0 10rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 22rpx;
}

.msg-list {
  height: calc(100vh - 96rpx);
}

.msg-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f1f2f6;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 46rpx;
  margin-right: 18rpx;
  background: #eef2f8;
}

.main {
  flex: 1;
  min-width: 0;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.name {
  max-width: 62%;
  font-size: 30rpx;
  color: #111;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  color: #9aa1ad;
  font-size: 22rpx;
}

.preview {
  margin-top: 8rpx;
  max-width: 78%;
  color: #7f8794;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dot {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 20rpx;
  padding: 0 8rpx;
}

.empty {
  margin-top: 180rpx;
  text-align: center;
}

.empty-main {
  display: block;
  color: #6f7885;
  font-size: 32rpx;
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  color: #a4aab6;
  font-size: 26rpx;
}

.go-btn {
  margin-top: 28rpx;
  width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: #1b86ff;
  color: #fff;
  font-size: 28rpx;
}