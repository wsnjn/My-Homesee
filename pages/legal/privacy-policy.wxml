<!--pages/legal/privacy-policy.wxml-->
<scroll-view scroll-y class="legal-scroll" style="height: 100vh;" enhanced show-scrollbar="{{true}}">
  <view class="legal-header">
    <text class="legal-title">隐私政策</text>
    <text class="legal-sub">生效日期：2026年3月20日</text>
    <text class="legal-sub">上次更新：2026年3月23日</text>
  </view>

  <block wx:for="{{sections}}" wx:key="title">
    <view class="section">
      <text class="section-title">{{item.title}}</text>
      <block wx:for="{{item.paragraphs}}" wx:for-item="p" wx:for-index="pIdx" wx:key="pIdx">
        <text class="section-p" user-select>{{p}}</text>
      </block>
      <block wx:if="{{item.bullets}}">
        <block wx:for="{{item.bullets}}" wx:for-item="b" wx:for-index="bIdx" wx:key="bIdx">
          <text class="section-p bullet" user-select>{{b}}</text>
        </block>
      </block>
    </view>
  </block>
</scroll-view>
