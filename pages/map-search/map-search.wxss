/* pages/map-search/map-search.wxss */
page {
  height: 100vh;
  overflow: hidden;
  background-color: #f5f5f5; /* Fallback background */
  padding: 0;
  margin: 0;
}

.container {
  height: 100vh; /* Use vh instead of % */
  width: 100vw;
  position: relative;
  padding: 0;
  margin: 0;
}

.top-nav {
  position: fixed;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  height: 76rpx;
  background: linear-gradient(135deg, rgba(15, 118, 110, 0.94), rgba(13, 148, 136, 0.9));
  border-radius: 22rpx;
  z-index: 150;
  display: flex;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(13, 148, 136, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.top-left {
  width: 72rpx;
  text-align: center;
  font-size: 42rpx;
  color: #fff;
  line-height: 1;
}

.top-title {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.top-right {
  min-width: 92rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  color: #a7f3d0;
  font-weight: 600;
  text-align: center;
}

/* Map Container */
/* Map Container */
.map {
  width: 100%;
  height: 100%;
}

/* Collapsible Sidebar - Right Side, Vertically Centered */
.sidebar {
  position: fixed;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 500rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: -8rpx 0 40rpx rgba(15, 23, 42, 0.12);
  z-index: 100;
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  border-radius: 28rpx 0 0 28rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.sidebar-closed {
  transform: translate(100%, -50%);
}

.sidebar-open {
  transform: translate(0, -50%);
}

.sidebar-content {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* Sidebar Search Bar */
.sidebar-search {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sidebar-search-input {
  flex: 1;
  background: #F3F4F6;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  color: #111827;
}

.sidebar-search-btn {
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(13, 148, 136, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: opacity 0.2s;
}

.sidebar-search-btn:active {
  opacity: 0.7;
}

/* Sidebar AI Button */
.sidebar-ai-btn {
  width: 100%;
  background: #2563EB;
  color: white;
  border: none;
  padding: 14rpx 0;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  transition: opacity 0.2s;
}

.sidebar-ai-btn:active {
  opacity: 0.8;
}

.sidebar-ai-btn[disabled] {
  background: #9CA3AF;
  opacity: 1;
}

/* 指定房源重新检测 */
.sidebar-specific {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sidebar-specific-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sidebar-specific-input {
  flex: 1;
  background: #F9FAFB;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: #111827;
}

.sidebar-recheck-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #10B981;
  color: #ffffff;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.sidebar-recheck-btn:active {
  opacity: 0.88;
}

.sidebar-recheck-btn.disabled {
  background: #9CA3AF;
  pointer-events: none;
}

.sidebar-recheck-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;
}

.sidebar-specific-hint {
  font-size: 20rpx;
  color: #6B7280;
  line-height: 1.4;
}

/* Sidebar Divider */
.sidebar-divider {
  height: 1px;
  background: #E5E7EB;
  margin: 8rpx 0;
}

.section-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6rpx 4rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

.section-arrow {
  font-size: 22rpx;
  color: #6b7280;
}


/* Sidebar Filters */
.sidebar-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sidebar-tag {
  padding: 10rpx 20rpx;
  background: #F3F4F6;
  color: #4B5563;
  font-size: 24rpx;
  font-weight: 500;
  border: 1px solid #E5E7EB;
  border-radius: 6rpx;
  transition: all 0.2s;
}

.sidebar-tag:active {
  transform: scale(0.95);
}

.sidebar-tag.active {
  background: #111827;
  color: white;
  border-color: #111827;
}

.sidebar-reset {
  margin-top: 4rpx;
  text-align: center;
  font-size: 24rpx;
  color: #2563EB;
  padding: 10rpx 0;
  border: 1px dashed #BFDBFE;
  border-radius: 8rpx;
}

.layer-switches {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.layer-btn {
  flex: 1 1 22%;
  text-align: center;
  font-size: 22rpx;
  color: #374151;
  background: #f3f4f6;
  border: 1px solid #e5e7eb;
  border-radius: 8rpx;
  padding: 10rpx 0;
}

.layer-btn.active {
  color: #1d4ed8;
  background: #eff6ff;
  border-color: #93c5fd;
}

/* Sidebar Toggle Button - Right Side */
.sidebar-toggle {
  position: fixed;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  background: white;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 101;
  font-size: 24rpx;
  color: #111827;
}

.room-strip {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 10rpx);
  z-index: 120;
  padding: 0 16rpx;
}

.room-strip-scroll {
  white-space: nowrap;
}

.room-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  width: 340rpx;
  min-height: 136rpx;
  margin-right: 12rpx;
  padding: 16rpx 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.1);
  border: 1px solid #e5e7eb;
}

.room-card.active {
  border-color: #2563EB;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.18);
}

.room-card-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.room-card-title {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
}

.room-card-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.room-card-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
}

.room-card-btn {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #ffffff;
  background: #2563EB;
  border-radius: 8rpx;
  padding: 8rpx 0;
}

.room-card-btn.ghost {
  color: #2563EB;
  background: #eff6ff;
  border: 1px solid #93c5fd;
}

.empty-result {
  position: fixed;
  left: 16rpx;
  right: 16rpx;
  bottom: calc(env(safe-area-inset-bottom) + 12rpx);
  z-index: 130;
}

.empty-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 14rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.12);
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.empty-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.empty-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.empty-btn {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #ffffff;
  background: #2563EB;
  border-radius: 8rpx;
  padding: 10rpx 0;
}

.empty-btn.ghost {
  color: #2563EB;
  background: #eff6ff;
  border: 1px solid #93c5fd;
}

.smart-title {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.smart-actions {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.smart-btn {
  font-size: 21rpx;
  color: #1d4ed8;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
}

/* Search Overlay - Rebuilt */
.search-overlay {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, 
    rgba(255,255,255,1) 0%, 
    rgba(255,255,255,0.95) 70%, 
    rgba(255,255,255,0) 100%);
  z-index: 10;
  /* Top padding, sides padding, safe area bottom padding */
  padding: 20rpx 20rpx calc(env(safe-area-inset-bottom) + 10rpx) 20rpx;
  display: flex;
  flex-direction: column; /* Search on top, filters below */
  gap: 16rpx;
  pointer-events: none;
}

.search-bar {
  display: flex;
  align-items: center;
  background: white;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  pointer-events: auto;
  margin: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
}

.placeholder {
  color: #9CA3AF;
}

.search-btn {
  width: 50rpx;
  height: 50rpx;
  background: #111827;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Filters */
.filter-tags {
  display: flex;
  white-space: nowrap;
  padding-left: 0;
  margin: 0;
  overflow-x: auto;
  pointer-events: auto;
  /* Hide scrollbar */
  -webkit-overflow-scrolling: touch;
}

.filter-tags::-webkit-scrollbar {
  display: none;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 40rpx;
  background: white;
  color: #4B5563;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
  border: 1px solid #E5E7EB;
  border-radius: 28rpx;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
  transition: all 0.2s;
  flex-shrink: 0;
}

.tag.active {
  background: #111827;
  color: white;
  border-color: #111827;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

/* Modal Content */
.modal-content {
  width: 680rpx;
  max-height: 80vh;
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  position: relative;
  overflow-y: auto;
  transform: scale(0.9);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-overlay.show .modal-content {
  transform: scale(1);
}

/* Close Button */
.modal-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6B7280;
  z-index: 10;
}

/* Modal Header */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding-right: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  flex: 1;
}

.modal-price {
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
  white-space: nowrap;
}

.unit {
  font-size: 24rpx;
  font-weight: 400;
  color: #6B7280;
}

/* Modal Info */
.modal-info {
  margin-bottom: 20rpx;
}

.info-text {
  font-size: 26rpx;
  color: #6B7280;
}

/* Modal Tags */
.modal-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.modal-tag {
  font-size: 22rpx;
  color: #4B5563;
  background: #F3F4F6;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
}

/* Modal AI Section */
.modal-ai-section {
  margin-top: 20rpx;
  margin-bottom: 24rpx;
  padding-top: 20rpx;
  border-top: 1px dashed #E5E7EB;
}

.ai-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.ai-title-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #2563EB;
}

.ai-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ai-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #F9FAFB;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  border: 1px solid #F3F4F6;
}

.ai-tag-text {
  font-size: 20rpx;
  color: #4B5563;
}

.ai-dist-text {
  color: #9CA3AF;
  margin-left: 4rpx;
}

.empty-text {
  color: #9CA3AF;
}

/* Modal Action Button */
.modal-action-btn {
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  width: 100%;
  border: none;
  padding: 24rpx 0;
  box-shadow: 0 12rpx 28rpx rgba(13, 148, 136, 0.35);
}

.modal-action-btn::after {
  border: none;
}

.loading-spinner {
  width: 20rpx;
  height: 20rpx;
  border: 2px solid #E5E7EB;
  border-top-color: #2563EB;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
