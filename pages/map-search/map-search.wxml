<!--pages/map-search/map-search.wxml-->
<view class="container">
  <view class="top-nav">
    <view class="top-left" bindtap="goBack">‹</view>
    <view class="top-title">Homesee 地图找房（{{resultCount}}）</view>
    <view class="top-right" bindtap="moveToUserLocation">定位</view>
  </view>

  <!-- Map Component (Full Screen) -->
  <map 
    id="map" 
    class="map"
    latitude="{{latitude}}" 
    longitude="{{longitude}}" 
    scale="{{scale}}"
    markers="{{markers}}"
    bindmarkertap="onMarkerTap"
    bindregionchange="onRegionChange"
    bindtap="onMapTap"
    show-location
  ></map>

  <!-- Collapsible Sidebar (Absolute Position) -->
  <view class="sidebar {{sidebarOpen ? 'sidebar-open' : 'sidebar-closed'}}">
    <view class="sidebar-content">
      <!-- Search Bar -->
      <view class="sidebar-search">
        <input 
          class="sidebar-search-input"
          value="{{searchText}}"
          placeholder="输入区域、地铁、小区名找房..." 
          placeholder-class="placeholder"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
        />
        <view class="sidebar-search-btn" bindtap="onSearchConfirm">
          <svg-icon name="search" size="18" color="#fff" />
        </view>
      </view>

      <!-- AI 完善数据（与 Web 端一致：仅处理缺坐标或默认中心点房源） -->
      <button class="sidebar-ai-btn" disabled="{{isProcessing}}" bindtap="startAICompletion">
        AI 完善数据
      </button>

      <!-- 指定房源重新检测 -->
      <view class="sidebar-specific">
        <view class="sidebar-specific-row">
          <input
            class="sidebar-specific-input"
            type="text"
            value="{{specificRoomId}}"
            placeholder="输入房源ID重新检测"
            placeholder-class="placeholder"
            disabled="{{isProcessing}}"
            bindinput="onSpecificRoomInput"
            bindconfirm="processSpecificRoom"
          />
          <view class="sidebar-recheck-btn {{isProcessing ? 'disabled' : ''}}" bindtap="processSpecificRoom">
            <svg-icon name="refresh-cw" size="16" color="#ffffff" />
            <text class="sidebar-recheck-text">重新检测</text>
          </view>
        </view>
        <text class="sidebar-specific-hint">输入房源编号，按地址重新解析经纬度并写回服务端</text>
      </view>

      <!-- Divider -->
      <view class="sidebar-divider"></view>

      <view class="section-toggle" bindtap="toggleBasicFilters">
        <text class="section-title">基础筛选</text>
        <text class="section-arrow">{{showBasicFilters ? '收起' : '展开'}}</text>
      </view>
      <view wx:if="{{showBasicFilters}}">
        <view class="sidebar-filters">
          <view 
            class="sidebar-tag {{activeFilters.includes('whole') ? 'active' : ''}}" 
            bindtap="toggleFilter" data-type="whole"
          >整租</view>
          <view 
            class="sidebar-tag {{activeFilters.includes('shared') ? 'active' : ''}}" 
            bindtap="toggleFilter" data-type="shared"
          >合租</view>
          <view 
            class="sidebar-tag {{activeFilters.includes('single') ? 'active' : ''}}" 
            bindtap="toggleFilter" data-type="single"
          >单间</view>
          <view 
            class="sidebar-tag {{activeFilters.includes('subway') ? 'active' : ''}}" 
            bindtap="toggleFilter" data-type="subway"
          >近地铁</view>
          <view 
            class="sidebar-tag {{activeFilters.includes('nearby') ? 'active' : ''}}" 
            bindtap="toggleFilter" data-type="nearby"
          >3km内</view>
          <view 
            class="sidebar-tag {{activeFilters.includes('viewport') ? 'active' : ''}}" 
            bindtap="toggleFilter" data-type="viewport"
          >视野内</view>
        </view>

        <view class="layer-switches">
          <view class="layer-btn {{activeRentalType === 'all' ? 'active' : ''}}" data-value="all" bindtap="onRentalTypeTap">全部</view>
          <view class="layer-btn {{activeRentalType === 'whole' ? 'active' : ''}}" data-value="whole" bindtap="onRentalTypeTap">整租</view>
          <view class="layer-btn {{activeRentalType === 'shared' ? 'active' : ''}}" data-value="shared" bindtap="onRentalTypeTap">合租</view>
          <view class="layer-btn {{activeRentalType === 'single' ? 'active' : ''}}" data-value="single" bindtap="onRentalTypeTap">单间</view>
        </view>

        <view class="layer-switches">
          <view class="layer-btn {{activePriceRange === 'all' ? 'active' : ''}}" data-value="all" bindtap="onPriceRangeTap">不限价格</view>
          <view class="layer-btn {{activePriceRange === 'lt2000' ? 'active' : ''}}" data-value="lt2000" bindtap="onPriceRangeTap">2000以下</view>
          <view class="layer-btn {{activePriceRange === '2000to4000' ? 'active' : ''}}" data-value="2000to4000" bindtap="onPriceRangeTap">2k-4k</view>
          <view class="layer-btn {{activePriceRange === 'gt4000' ? 'active' : ''}}" data-value="gt4000" bindtap="onPriceRangeTap">4000以上</view>
        </view>
      </view>

      <view class="section-toggle" bindtap="toggleAdvancedFilters">
        <text class="section-title">高级筛选</text>
        <text class="section-arrow">{{showAdvancedFilters ? '收起' : '展开'}}</text>
      </view>
      <view wx:if="{{showAdvancedFilters}}">
        <view class="layer-switches">
          <view class="layer-btn {{showMetroLayer ? 'active' : ''}}" bindtap="toggleMetroLayer">地铁图层</view>
          <view class="layer-btn {{showBusinessLayer ? 'active' : ''}}" bindtap="toggleBusinessLayer">商圈图层</view>
        </view>

        <view class="layer-switches">
          <view class="layer-btn {{sortType === 'default' ? 'active' : ''}}" data-value="default" bindtap="onSortTap">默认排序</view>
          <view class="layer-btn {{sortType === 'price_asc' ? 'active' : ''}}" data-value="price_asc" bindtap="onSortTap">价格升序</view>
          <view class="layer-btn {{sortType === 'distance_asc' ? 'active' : ''}}" data-value="distance_asc" bindtap="onSortTap">离我最近</view>
        </view>
      </view>

      <view class="sidebar-reset" bindtap="resetFilters">重置筛选</view>
    </view>
  </view>

  <!-- Sidebar Toggle Button -->
  <view class="sidebar-toggle" bindtap="toggleSidebar">
    <svg-icon wx:if="{{sidebarOpen}}" name="arrow-left" size="20" color="#111827" />
    <svg-icon wx:else name="arrow-right" size="20" color="#111827" />
  </view>

  <view class="room-strip" wx:if="{{filteredRooms.length}}">
    <scroll-view class="room-strip-scroll" scroll-x="true" show-scrollbar="false" enhanced="true" scroll-into-view="{{cardScrollIntoView}}">
      <view
        wx:for="{{filteredRooms}}"
        wx:key="id"
        wx:for-item="room"
        id="room-card-{{room.id}}"
        class="room-card {{activeRoomId == room.id ? 'active' : ''}}"
        data-id="{{room.id}}"
        bindtap="onRoomCardTap"
      >
        <view class="room-card-price">¥{{room.rentPrice}}/月</view>
        <view class="room-card-title">{{room.communityName || '房源'}}</view>
        <view class="room-card-meta">{{room.bedroomCount || 1}}室{{room.parlorCount || 1}}厅 · {{room.roomArea || '-'}}㎡</view>
        <view class="room-card-actions">
          <view class="room-card-btn ghost" data-id="{{room.id}}" catchtap="toggleCardFavorite">
            {{room.isFavorite ? '已收藏' : '收藏'}}
          </view>
          <view class="room-card-btn" data-id="{{room.id}}" catchtap="quickAppointment">预约</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="empty-result" wx:if="{{!filteredRooms.length}}">
    <view class="empty-card">
      <view class="empty-title">当前条件下暂无房源</view>
      <view class="empty-sub">试试放宽筛选条件，或拖动地图到其他区域</view>
      <view class="empty-actions">
        <view class="empty-btn ghost" bindtap="quickRelaxViewport">关闭视野内</view>
        <view class="empty-btn ghost" bindtap="quickRelaxPrice">放宽价格</view>
        <view class="empty-btn" bindtap="quickClearAll">清空筛选</view>
      </view>

      <view class="smart-title">智能建议</view>
      <view class="smart-actions">
        <view
          wx:for="{{smartSuggestions}}"
          wx:key="key"
          class="smart-btn"
          data-key="{{item.key}}"
          bindtap="applySuggestion"
        >
          {{item.text}}
        </view>
      </view>
    </view>
  </view>


  <!-- Room Detail Modal -->
  <view class="modal-overlay {{showDetail ? 'show' : ''}}" wx:if="{{selectedRoom}}" bindtap="closeDetail">
    <view class="modal-content" catchtap="preventBubble">
      <!-- Close Button -->
      <view class="modal-close" bindtap="closeDetail">
        <svg-icon name="close" size="22" color="#6B7280" />
      </view>

      <!-- Header -->
      <view class="modal-header">
        <text class="modal-title">{{selectedRoom.communityName}} {{selectedRoom.roomNumber || ''}}</text>
        <text class="modal-price">¥{{selectedRoom.rentPrice}}<text class="unit">/月</text></text>
      </view>

      <!-- Info -->
      <view class="modal-info">
        <text class="info-text">{{selectedRoom.bedroomCount || 1}}室{{selectedRoom.parlorCount || 1}}厅 | {{selectedRoom.roomArea}}㎡ | {{selectedRoom.direction || '南'}}</text>
      </view>

      <!-- Tags -->
      <view class="modal-tags">
        <block wx:if="{{selectedRoom.tagsList && selectedRoom.tagsList.length}}">
          <text class="modal-tag" wx:for="{{selectedRoom.tagsList}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </block>
        <text class="modal-tag" wx:else>随时看房</text>
        <text class="modal-tag" wx:if="{{selectedRoom.rentalType === 0}}">整租</text>
        <text class="modal-tag" wx:elif="{{selectedRoom.rentalType === 1}}">合租</text>
        <text class="modal-tag" wx:elif="{{selectedRoom.rentalType === 2}}">单间</text>
      </view>

      <!-- AI Analysis Section -->
      <view class="modal-ai-section">
        <view class="ai-title">
          <svg-icon name="ai-sparkle" size="14" color="#2563EB" />
          <text class="ai-title-text">AI 周边配套分析</text>
        </view>
        <view class="ai-tags">
           <!-- Loading State -->
           <view class="ai-tag loading" wx:if="{{aiLoading}}">
             <view class="loading-spinner"></view>
             <text class="ai-tag-text">AI 正在分析周边配套...</text>
           </view>

           <!-- Result List -->
           <block wx:else>
             <view class="ai-tag" wx:for="{{aiItems}}" wx:key="name">
                <svg-icon name="{{item.type}}" size="12" color="{{item.color}}" />
                <text class="ai-tag-text">{{item.name}} <text class="ai-dist-text">{{item.distance}}m</text></text>
             </view>
             
             <!-- Empty State -->
             <view class="ai-tag" wx:if="{{aiItems.length === 0}}">
                <text class="ai-tag-text empty-text">暂无周边配套数据</text>
             </view>
           </block>
        </view>
      </view>

      <!-- Action Button -->
      <button class="modal-action-btn" bindtap="navigateToDetail">查看详情</button>
    </view>
  </view>

</view>
