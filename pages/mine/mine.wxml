<view class="mine-page">
  <view class="profile-card" bindtap="goProfile">
    <image class="avatar" src="{{user && user.avatar ? (user.avatar.indexOf('http') === 0 ? user.avatar : 'https://files.homesee.xyz/api/files/download/' + user.avatar) : 'https://files.homesee.xyz/api/files/download/default-avatar.png'}}" mode="aspectFill" />
    <view class="profile-main">
      <view class="name">{{user ? (user.realName || user.username || '新用户') : '新用户'}}</view>
      <view class="phone">{{user ? user.phone : '未登录'}}</view>
    </view>
    <view class="arrow">›</view>
  </view>

  <view class="menu-card">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="key" data-key="{{item.key}}" bindtap="onMenuTap">
      <view class="menu-left">
        <text class="menu-icon">◦</text>
        <text>{{item.text}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="logout">退出登录</button>
  <view class="version">版本信息: 1.0.54</view>
</view>
