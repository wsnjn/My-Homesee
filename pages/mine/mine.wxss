.mine-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #042f2e 0%, #0f766e 36%, #f0fdfa 36%, #ecfeff 100%);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.mine-hero {
  position: relative;
  padding: 36rpx 28rpx 100rpx;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  width: 360rpx;
  height: 360rpx;
  right: -100rpx;
  top: -120rpx;
  background: radial-gradient(circle, rgba(94, 234, 212, 0.45) 0%, transparent 65%);
  pointer-events: none;
}

.profile-row {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  position: relative;
  width: 128rpx;
  height: 128rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.2);
}

.avatar-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 44rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.45);
  pointer-events: none;
}

.profile-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}

.phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 4rpx;
}

.mini-tag {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.chev {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.65);
  font-weight: 300;
}

.mine-body {
  margin-top: -72rpx;
  position: relative;
  z-index: 3;
  padding: 0 24rpx;
}

.section-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-tile {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 26rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.menu-tile-hover {
  transform: scale(0.99);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.tile-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tile-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tile-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.tile-sub {
  font-size: 22rpx;
  color: #94a3b8;
}

.tile-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
}

.logout-btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #dc2626;
  font-size: 30rpx;
  font-weight: 700;
  border: 2rpx solid rgba(252, 165, 165, 0.6);
  box-shadow: 0 12rpx 32rpx rgba(220, 38, 38, 0.08);
}

.logout-btn::after {
  border: none;
}

.logout-btn-hover {
  opacity: 0.92;
}

.version {
  margin-top: 28rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 22rpx;
}
