/* pages/house-selection/house-selection.wxss — 极光栖居 · 看房页 */

.hs-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #042f2e 0%, #0f766e 12%, #ecfeff 12%, #f0fdfa 42%, #f8fafc 100%);
  box-sizing: border-box;
}

.hs-top-zone {
  padding: 16rpx 24rpx 0;
  flex-shrink: 0;
}

.hs-map-shell {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  height: 300rpx;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.hs-map {
  width: 100%;
  height: 100%;
}

.hs-map-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: linear-gradient(180deg, transparent, rgba(15, 23, 42, 0.55));
  pointer-events: none;
  z-index: 2;
}

.hs-map-bar {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
}

.hs-map-bar-ico {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hs-map-bar-txt {
  flex: 1;
  font-size: 24rpx;
  color: #334155;
  font-weight: 600;
}

.hs-map-bar-go {
  font-size: 22rpx;
  font-weight: 800;
  color: #0d9488;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(204, 251, 241, 0.9);
}

/* 悬浮筛选卡 */
.hs-float {
  position: relative;
  z-index: 5;
  margin: -44rpx 24rpx 0;
  padding: 22rpx 20rpx 20rpx;
  border-radius: 32rpx;
  background: linear-gradient(165deg, rgba(255, 255, 255, 0.97) 0%, rgba(240, 253, 250, 0.96) 100%);
  border: 1rpx solid rgba(153, 246, 228, 0.5);
  box-shadow: 0 20rpx 50rpx rgba(13, 148, 136, 0.15), 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  opacity: 0;
  transform: translateY(28rpx);
}

.hs-float-in {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1), transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.hs-float-kicker {
  font-size: 22rpx;
  font-weight: 700;
  color: #0f766e;
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
}

.hs-float-kicker.row2 {
  margin-top: 18rpx;
}

.room-tabs {
  display: flex;
  gap: 10rpx;
  padding: 6rpx;
  background: #f1f5f9;
  border-radius: 22rpx;
}

.room-tab {
  flex: 1;
  text-align: center;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  color: #64748b;
  border-radius: 18rpx;
  font-weight: 600;
}

.room-tab.active {
  color: #fff;
  font-weight: 800;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  box-shadow: 0 8rpx 20rpx rgba(13, 148, 136, 0.35);
}

.search-bar {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-input-wrap {
  flex: 1;
  position: relative;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 52rpx 0 24rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.search-ph {
  color: #94a3b8;
}

.search-icon-wrap {
  position: absolute;
  right: 22rpx;
  top: 50%;
  transform: translateY(-50%);
}

.filter-btn {
  width: 128rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  margin: 0;
  background: linear-gradient(135deg, #0d9488, #2dd4bf);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(13, 148, 136, 0.35);
}

.filter-btn::after {
  border: none;
}

.filter-btn-hover {
  opacity: 0.92;
}

.bedroom-row {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 4rpx;
}

.bedroom-opt {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 8rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
}

.bedroom-ring {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bedroom-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: transparent;
}

.bedroom-opt.active .bedroom-ring {
  border-color: #0d9488;
  box-shadow: 0 0 0 6rpx rgba(13, 148, 136, 0.15);
}

.bedroom-opt.active .bedroom-dot {
  background: linear-gradient(135deg, #0d9488, #2dd4bf);
}

.bedroom-opt.active {
  background: #ecfdf5;
  border-color: #99f6e4;
}

.bedroom-txt {
  font-size: 22rpx;
  color: #475569;
  font-weight: 600;
}

.bedroom-opt.active .bedroom-txt {
  color: #0f766e;
  font-weight: 800;
}

/* 灵感快选 */
.hs-quick-block {
  padding: 28rpx 24rpx 8rpx;
  flex-shrink: 0;
  opacity: 0;
  transform: translateY(20rpx);
}

.hs-quick-in {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.08s, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.08s;
}

.hs-sec-head {
  margin-bottom: 16rpx;
}

.hs-sec-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.hs-sec-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.quick-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 8rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.quick-tile-hover {
  transform: scale(0.97);
  box-shadow: 0 6rpx 18rpx rgba(13, 148, 136, 0.12);
}

.quick-ico {
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-label {
  font-size: 20rpx;
  color: #475569;
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
}

/* 横向 chips */
.hs-chip-bar {
  display: flex;
  gap: 10rpx;
  padding: 12rpx 24rpx 16rpx;
  flex-shrink: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.hs-chip-bar::-webkit-scrollbar {
  display: none;
}

.hs-chip {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(153, 246, 228, 0.45);
  font-size: 22rpx;
  font-weight: 600;
  color: #334155;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.hs-chip-sort {
  max-width: 240rpx;
}

.hs-chip-sort-main {
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hs-chip-chev {
  font-size: 18rpx;
  color: #94a3b8;
}

/* 列表标题条 */
.hs-list-banner {
  margin: 0 24rpx 12rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(125deg, rgba(15, 118, 110, 0.12), rgba(45, 212, 191, 0.12));
  border: 1rpx solid rgba(13, 148, 136, 0.2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.hs-list-banner-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.hs-list-banner-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #0d9488;
  font-weight: 600;
}

.hs-list-banner-sub.muted {
  color: #94a3b8;
}

.hs-list-banner-tag {
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  box-shadow: 0 8rpx 20rpx rgba(13, 148, 136, 0.3);
}

/* 列表滚动区 */
.house-list {
  flex: 1;
  height: 0;
  min-height: 320rpx;
  padding: 0 0 env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.hs-list-pad {
  height: 24rpx;
}

/* 空状态 */
.empty-wrap {
  padding: 40rpx 0 20rpx;
}

.empty-card {
  margin: 0 8rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  border: 1rpx dashed rgba(13, 148, 136, 0.35);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.05);
}

.empty-ico {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #334155;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.5;
}

.empty-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-top: 28rpx;
}

.empty-pill {
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #0d9488;
  background: #ecfdf5;
  border: 1rpx solid #99f6e4;
}

.empty-pill.primary {
  color: #fff;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(13, 148, 136, 0.3);
}

/* 房源卡片 */
.house-card {
  margin: 0 24rpx 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.07);
  opacity: 0;
  transform: translateY(16rpx);
}

.house-card-in {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.4s ease, transform 0.4s ease;
}

.house-image-wrap {
  position: relative;
  height: 380rpx;
  overflow: hidden;
}

.house-image {
  width: 100%;
  height: 100%;
}

.house-image-hover .vr-layer {
  opacity: 1;
}

.house-tags {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  display: flex;
  gap: 10rpx;
  z-index: 2;
}

.tag {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  border-radius: 12rpx;
}

.tag.status.on {
  background: linear-gradient(135deg, #10b981, #34d399);
}

.tag.status.off {
  background: #64748b;
}

.tag.type {
  background: rgba(15, 23, 42, 0.88);
}

.vr-layer {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s ease;
  z-index: 3;
}

.vr-btn {
  padding: 18rpx 40rpx !important;
  border-radius: 999rpx !important;
  background: linear-gradient(135deg, #fff, #ecfeff) !important;
  color: #0f766e !important;
  font-size: 28rpx !important;
  font-weight: 800 !important;
  border: none !important;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.15) !important;
}

.vr-btn::after {
  border: none !important;
}

.house-body {
  padding: 24rpx 24rpx 26rpx;
}

.house-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.3;
}

.house-addr {
  margin-top: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.house-addr-txt {
  flex: 1;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.4;
}

.house-phone {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.house-meta {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.meta-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #475569;
  background: #f1f5f9;
}

.house-foot {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price-box {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.price-yen {
  font-size: 26rpx;
  font-weight: 800;
  color: #0d9488;
}

.price-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #0d9488;
}

.price-unit {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 4rpx;
}

.house-stats {
  margin-left: auto;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  align-items: flex-end;
  font-size: 20rpx;
  color: #94a3b8;
}

.book-btn {
  flex-shrink: 0;
  margin-left: 8rpx;
  padding: 0 28rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  border-radius: 999rpx !important;
  font-size: 24rpx !important;
  font-weight: 700 !important;
  color: #fff !important;
  background: linear-gradient(135deg, #0d9488, #14b8a6) !important;
  border: none !important;
  box-shadow: 0 8rpx 20rpx rgba(13, 148, 136, 0.3) !important;
}

.book-btn::after {
  border: none !important;
}

.book-btn.disabled {
  background: #f1f5f9 !important;
  color: #94a3b8 !important;
  box-shadow: none !important;
}

/* 加载 / 底部 */
.load-box {
  padding: 48rpx;
  text-align: center;
}

.load-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.load-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #0d9488;
  animation: hsBounce 0.9s ease-in-out infinite;
}

.load-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.load-dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes hsBounce {
  0%,
  80%,
  100% {
    transform: scale(0.7);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.load-txt {
  font-size: 24rpx;
  color: #94a3b8;
}

.end-box {
  padding: 32rpx;
  text-align: center;
}

.end-txt {
  font-size: 22rpx;
  color: #cbd5e1;
}

/* 筛选全屏 */
.filter-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.48);
  z-index: 999;
}

.filter-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 12vh;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f8fafc 0%, #fff 18%);
  border-radius: 36rpx 36rpx 0 0;
  overflow: hidden;
  box-shadow: 0 -20rpx 60rpx rgba(15, 23, 42, 0.12);
}

.filter-top {
  padding: 28rpx 28rpx 20rpx;
  background: linear-gradient(135deg, #0f766e 0%, #0d9488 50%, #14b8a6 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filter-top-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
}

.filter-reset {
  margin: 0;
  padding: 10rpx 24rpx;
  line-height: 1.2;
  font-size: 24rpx;
  font-weight: 700;
  color: #0f766e;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  border: none;
}

.filter-reset::after {
  border: none;
}

.filter-scroll {
  flex: 1;
  height: 0;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

.filter-scroll-pad {
  height: 40rpx;
}

.filter-block {
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.filter-block:last-of-type {
  border-bottom: none;
}

.filter-cap {
  font-size: 22rpx;
  font-weight: 800;
  color: #94a3b8;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.filter-row2 {
  display: flex;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.pick-half {
  flex: 1;
}

.pick-cell {
  padding: 22rpx 20rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
}

.pick-full {
  width: 100%;
  box-sizing: border-box;
}

.range-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.range-inp {
  flex: 1;
  padding: 22rpx 20rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.range-gap {
  color: #cbd5e1;
  font-size: 24rpx;
}

.filter-foot {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f1f5f9;
  background: rgba(255, 255, 255, 0.98);
}

.foot-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #64748b;
  background: #f1f5f9;
  border: none;
}

.foot-cancel::after {
  border: none;
}

.foot-ok {
  flex: 1.2;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #0d9488, #2dd4bf);
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(13, 148, 136, 0.35);
}

.foot-ok::after {
  border: none;
}
