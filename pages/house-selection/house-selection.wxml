<!-- pages/house-selection/house-selection.wxml — 极光栖居主题 -->
<view class="hs-page">
  <view class="hs-top-zone">
    <view class="hs-map-shell">
      <map
        class="hs-map"
        latitude="{{topMapLatitude}}"
        longitude="{{topMapLongitude}}"
        scale="{{topMapScale}}"
        markers="{{topMapMarkers}}"
        show-location
        bindmarkertap="onTopMapMarkerTap"
        bindtap="goMapSearch"
      />
      <view class="hs-map-gradient"></view>
      <view class="hs-map-bar" bindtap="goMapSearch">
        <view class="hs-map-bar-ico">
          <svg-icon name="map" size="22" color="#0d9488" />
        </view>
        <text class="hs-map-bar-txt">地图找房 · 点按进入全屏选点</text>
        <text class="hs-map-bar-go">去地图</text>
      </view>
    </view>
  </view>

  <view class="hs-float {{animReady ? 'hs-float-in' : ''}}">
    <view class="hs-float-kicker">租赁方式</view>
    <view class="room-tabs">
      <view
        wx:for="{{roomTabs}}"
        wx:key="*this"
        class="room-tab {{activeRoomTab === item ? 'active' : ''}}"
        data-tab="{{item}}"
        bindtap="onRoomTabTap"
      >{{item}}</view>
    </view>

    <view class="search-bar">
      <view class="search-input-wrap">
        <input
          class="search-input"
          placeholder="搜商圈、小区、地铁站"
          placeholder-class="search-ph"
          value="{{searchKeyword}}"
          bindinput="onSearch"
        />
        <view class="search-icon-wrap">
          <svg-icon name="search" size="18" color="#0d9488" />
        </view>
      </view>
      <button class="filter-btn" hover-class="filter-btn-hover" bindtap="toggleFilterPanel">筛选</button>
    </view>

    <view class="hs-float-kicker row2">户型偏好</view>
    <view class="bedroom-row">
      <view
        wx:for="{{bedroomOptions}}"
        wx:key="value"
        class="bedroom-opt {{activeBedroom === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onBedroomTap"
      >
        <view class="bedroom-ring">
          <view class="bedroom-dot"></view>
        </view>
        <text class="bedroom-txt">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="hs-quick-block {{animReady ? 'hs-quick-in' : ''}}">
    <view class="hs-sec-head">
      <text class="hs-sec-title">灵感快选</text>
      <text class="hs-sec-sub">一键倾向，结果即时刷新</text>
    </view>
    <view class="quick-grid">
      <view
        wx:for="{{topShortcuts}}"
        wx:key="key"
        class="quick-tile"
        hover-class="quick-tile-hover"
        data-key="{{item.key}}"
        bindtap="onTopShortcutTap"
      >
        <view class="quick-ico">
          <svg-icon name="{{item.icon}}" size="40" color="#0d9488" />
        </view>
        <text class="quick-label">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="hs-chip-bar">
    <view class="hs-chip" data-key="location" bindtap="onDetailFilterTap">
      <text>位置</text>
      <text class="hs-chip-chev">▼</text>
    </view>
    <view class="hs-chip" data-key="houseType" bindtap="onDetailFilterTap">
      <text>房型</text>
      <text class="hs-chip-chev">▼</text>
    </view>
    <view class="hs-chip" data-key="rent" bindtap="onDetailFilterTap">
      <text>租金</text>
      <text class="hs-chip-chev">▼</text>
    </view>
    <view class="hs-chip" data-key="filter" bindtap="onDetailFilterTap">
      <text>更多</text>
      <text class="hs-chip-chev">▼</text>
    </view>
    <view class="hs-chip hs-chip-sort" data-key="sort" bindtap="onDetailFilterTap">
      <text class="hs-chip-sort-main">{{sortLabel}}</text>
      <text class="hs-chip-chev">↻</text>
    </view>
  </view>

  <view class="hs-list-banner">
    <view class="hs-list-banner-left">
      <text class="hs-list-banner-title">甄选房源</text>
      <text class="hs-list-banner-sub" wx:if="{{!loading}}">为你匹配 {{listCount}} 套</text>
      <text class="hs-list-banner-sub muted" wx:else>加载中…</text>
    </view>
    <view class="hs-list-banner-tag">Homesee</view>
  </view>

  <scroll-view
    class="house-list"
    scroll-y
    bindscrolltolower="onReachBottom"
    enable-back-to-top
    enhanced
    show-scrollbar="{{false}}"
  >
    <view wx:if="{{houses.length === 0 && !loading}}" class="empty-wrap">
      <view class="empty-card">
        <view class="empty-ico">
          <svg-icon name="home" size="56" color="#cbd5e1" />
        </view>
        <text class="empty-title">暂时没有符合条件的房源</text>
        <text class="empty-desc">试试放宽户型、租金或清空关键词</text>
        <view class="empty-actions">
          <view class="empty-pill" bindtap="onQuickResetList">重置筛选</view>
          <view class="empty-pill primary" bindtap="toggleFilterPanel">打开筛选</view>
        </view>
      </view>
    </view>

    <view
      wx:for="{{houses}}"
      wx:key="id"
      class="house-card {{animReady ? 'house-card-in' : ''}}"
      style="transition-delay: {{index * 40}}ms;"
      bindtap="goHouseDetail"
      data-id="{{item.id}}"
    >
      <view class="house-image-wrap" hover-class="house-image-hover" hover-stay-time="100">
        <image
          class="house-image"
          src="{{item.coverImage || 'https://files.homesee.xyz/api/files/download/客厅.jpg'}}"
          mode="aspectFill"
        />
        <view class="house-tags">
          <view class="tag status {{item.status === 0 ? 'on' : 'off'}}">
            {{item.status === 0 ? '在租' : '已下架'}}
          </view>
          <view class="tag type">
            {{item.rentalType === 0 ? '整租' : (item.rentalType === 1 ? '合租' : '单间')}}
          </view>
        </view>
        <view class="vr-layer">
          <button class="vr-btn" catchtap="goToHouseTour" data-id="{{item.id}}">VR 看房</button>
        </view>
      </view>

      <view class="house-body">
        <view class="house-title">{{item.district}} {{item.doorNumber || ''}}</view>
        <view class="house-addr">
          <svg-icon name="location" size="26" color="#0d9488" />
          <text class="house-addr-txt">{{item.city}}{{item.district}}{{item.street}}</text>
        </view>
        <view wx:if="{{item.landlordPhone}}" class="house-phone">房东 {{item.formattedPhone || item.landlordPhone}}</view>
        <view class="house-meta">
          <text class="meta-pill">{{item.roomArea}}㎡</text>
          <text class="meta-pill">{{item.floorInfo || '中层'}}</text>
          <text class="meta-pill">
            {{item.decoration === 1 ? '毛坯' : (item.decoration === 2 ? '简装' : (item.decoration === 3 ? '精装' : '豪装'))}}
          </text>
        </view>
        <view class="house-foot">
          <view class="price-box">
            <text class="price-yen">¥</text>
            <text class="price-num">{{item.rentPrice}}</text>
            <text class="price-unit">/月</text>
          </view>
          <view class="house-stats">
            <text>{{item.viewCount || 0}} 浏览</text>
            <text>{{item.consultCount || 0}} 咨询</text>
          </view>
          <button
            class="book-btn {{item.status !== 0 ? 'disabled' : ''}}"
            catchtap="goToAppointment"
            data-id="{{item.id}}"
            data-status="{{item.status}}"
          >
            {{item.status === 0 ? '预约看房' : '已下架'}}
          </button>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="load-box">
      <view class="load-dots">
        <view class="load-dot"></view>
        <view class="load-dot"></view>
        <view class="load-dot"></view>
      </view>
      <text class="load-txt">正在加载房源…</text>
    </view>

    <view wx:if="{{!hasMore && houses.length > 0}}" class="end-box">
      <text class="end-txt">已经到底啦 · 换个条件试试</text>
    </view>
    <view class="hs-list-pad"></view>
  </scroll-view>

  <!-- 筛选全屏 -->
  <view wx:if="{{showFilterPanel}}" class="filter-panel">
    <view class="filter-top">
      <text class="filter-top-title">筛选条件</text>
      <button class="filter-reset" bindtap="resetFilters">重置</button>
    </view>

    <scroll-view scroll-y class="filter-scroll" enhanced show-scrollbar="{{false}}">
      <view class="filter-block">
        <view class="filter-cap">区域选择</view>
        <view class="filter-row2">
          <picker mode="selector" range="{{provinces}}" value="{{selectedProvinceIndex}}" bindchange="onProvinceChange" class="pick-half">
            <view class="pick-cell">{{selectedProvince || '省份'}}</view>
          </picker>
          <picker mode="selector" range="{{cities}}" value="{{selectedCityIndex}}" bindchange="onCityChange" class="pick-half">
            <view class="pick-cell">{{selectedCity || '城市'}}</view>
          </picker>
        </view>
        <view class="filter-row2">
          <picker mode="selector" range="{{districts}}" value="{{selectedDistrictIndex}}" bindchange="onDistrictChange" class="pick-half">
            <view class="pick-cell">{{selectedDistrict || '区县'}}</view>
          </picker>
          <picker mode="selector" range="{{streets}}" value="{{selectedStreetIndex}}" bindchange="onStreetChange" class="pick-half">
            <view class="pick-cell">{{selectedStreet || '街道'}}</view>
          </picker>
        </view>
        <picker mode="selector" range="{{communities}}" value="{{selectedCommunityIndex}}" bindchange="onCommunityChange">
          <view class="pick-cell pick-full">{{selectedCommunity || '小区'}}</view>
        </picker>
      </view>

      <view class="filter-block">
        <view class="filter-cap">基本筛选</view>
        <view class="filter-row2">
          <picker mode="selector" range="{{rentalTypeOptions}}" range-key="label" value="{{selectedRentalTypeIndex}}" bindchange="onRentalTypeChange" class="pick-half">
            <view class="pick-cell">{{selectedRentalType || '租赁类型'}}</view>
          </picker>
          <picker mode="selector" range="{{decorationOptions}}" range-key="label" value="{{selectedDecorationIndex}}" bindchange="onDecorationChange" class="pick-half">
            <view class="pick-cell">{{selectedDecoration || '装修程度'}}</view>
          </picker>
        </view>
        <view class="filter-row2">
          <picker mode="selector" range="{{elevatorOptions}}" range-key="label" value="{{selectedElevatorIndex}}" bindchange="onElevatorChange" class="pick-half">
            <view class="pick-cell">{{selectedElevator || '电梯'}}</view>
          </picker>
          <picker mode="selector" range="{{orientationOptions}}" range-key="label" value="{{selectedOrientationIndex}}" bindchange="onOrientationChange" class="pick-half">
            <view class="pick-cell">{{selectedOrientation || '朝向'}}</view>
          </picker>
        </view>
      </view>

      <view class="filter-block">
        <view class="filter-cap">价格与面积</view>
        <view class="range-line">
          <input class="range-inp" type="number" placeholder="最低租金" value="{{minPrice}}" bindinput="onMinPriceInput" />
          <text class="range-gap">—</text>
          <input class="range-inp" type="number" placeholder="最高租金" value="{{maxPrice}}" bindinput="onMaxPriceInput" />
        </view>
        <view class="range-line">
          <input class="range-inp" type="number" placeholder="最小面积" value="{{minArea}}" bindinput="onMinAreaInput" />
          <text class="range-gap">—</text>
          <input class="range-inp" type="number" placeholder="最大面积" value="{{maxArea}}" bindinput="onMaxAreaInput" />
        </view>
      </view>
      <view class="filter-scroll-pad"></view>
    </scroll-view>

    <view class="filter-foot">
      <button class="foot-cancel" bindtap="toggleFilterPanel">取消</button>
      <button class="foot-ok" bindtap="applyFilters">应用筛选</button>
    </view>
  </view>

  <view wx:if="{{showFilterPanel}}" class="filter-mask" bindtap="toggleFilterPanel"></view>
</view>
