page {
  background: #f6f7fb;
}

.home-page {
  min-height: 100vh;
  background: #fff;
}

.top-red {
  padding: 20rpx 20rpx 24rpx;
  background: linear-gradient(180deg, #de1b28 0%, #ff6a75 100%);
  border-bottom-left-radius: 28rpx;
  border-bottom-right-radius: 28rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.placeholder {
  color: #a2a7b3;
  font-size: 28rpx;
}

.round-btn {
  width: 54rpx;
  height: 54rpx;
  border-radius: 27rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.quick4 {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.q-item {
  height: 88rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner {
  margin-top: 20rpx;
  height: 130rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-grid {
  margin: 24rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.s-item {
  height: 96rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  color: #1f2530;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.todo-empty {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #9ea4b0;
  font-size: 30rpx;
}

.empty-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
