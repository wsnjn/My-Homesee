.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #042f2e 0%, #0f766e 22%, #14b8a6 48%, #f0fdfa 48%, #ecfeff 100%);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.hero {
  position: relative;
  padding: 24rpx 28rpx 120rpx;
  overflow: hidden;
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(2rpx);
  opacity: 0.35;
  pointer-events: none;
}

.hero-blob-a {
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, #5eead4 0%, transparent 70%);
  top: -60rpx;
  right: -40rpx;
}

.hero-blob-b {
  width: 220rpx;
  height: 220rpx;
  background: radial-gradient(circle, #fbbf24 0%, transparent 70%);
  bottom: 40rpx;
  left: -50rpx;
  opacity: 0.25;
}

.hero-inner {
  position: relative;
  z-index: 2;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-block {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-mark {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.95) 0%, rgba(204, 251, 241, 0.9) 100%);
  color: #0f766e;
  font-size: 40rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.12);
}

.brand-texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

.brand-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
}

.hero-weather-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.weather-ico {
  display: flex;
  align-items: center;
  justify-content: center;
}

.weather-txt {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.92);
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.greeting-block {
  margin-top: 36rpx;
}

.greeting-hi {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.25;
}

.greeting-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
}

.search-pill {
  margin-top: 28rpx;
  height: 96rpx;
  border-radius: 48rpx;
  padding: 0 12rpx 0 28rpx;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 20rpx 50rpx rgba(15, 23, 42, 0.12);
}

.search-pill-hover {
  transform: scale(0.99);
  opacity: 0.96;
}

.search-ico {
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #94a3b8;
}

.search-go {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #0d9488, #2dd4bf);
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.35);
}

.orbit-row {
  margin-top: 32rpx;
  display: flex;
  justify-content: space-between;
  padding: 0 8rpx;
}

.orbit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 22%;
}

.orbit-item-hover .orbit-ring {
  transform: translateY(-4rpx) scale(1.04);
}

.orbit-ring {
  width: 100rpx;
  height: 100rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  transition: transform 0.2s ease;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.08);
}

.orbit-coral {
  background: linear-gradient(160deg, rgba(255, 237, 213, 0.95), rgba(254, 215, 170, 0.75));
}

.orbit-teal {
  background: linear-gradient(160deg, rgba(204, 251, 241, 0.95), rgba(153, 246, 228, 0.75));
}

.orbit-violet {
  background: linear-gradient(160deg, rgba(237, 233, 254, 0.95), rgba(196, 181, 253, 0.75));
}

.orbit-sky {
  background: linear-gradient(160deg, rgba(224, 242, 254, 0.95), rgba(125, 211, 252, 0.75));
}

.orbit-emoji {
  font-size: 40rpx;
}

.orbit-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.92);
  text-align: center;
}

.sheet {
  margin-top: -88rpx;
  position: relative;
  z-index: 3;
  padding: 0 24rpx;
}

.quick-strip {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
  margin-bottom: 8rpx;
  -webkit-overflow-scrolling: touch;
}

.quick-strip::-webkit-scrollbar {
  display: none;
}

.chip {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(13, 148, 136, 0.15);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.chip-pulse {
  animation: chipPulse 0.45s ease;
}

@keyframes chipPulse {
  0% {
    transform: scale(1);
  }
  40% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

.chip-ico {
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-txt {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
}

.promo-card {
  position: relative;
  margin-top: 12rpx;
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(125deg, #1e293b 0%, #0f766e 48%, #0ea5e9 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: 0 24rpx 48rpx rgba(15, 118, 110, 0.35);
}

.promo-card-hover {
  opacity: 0.94;
}

.promo-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  right: -40rpx;
  top: -60rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.35) 0%, transparent 70%);
  pointer-events: none;
}

.promo-body {
  flex: 1;
  position: relative;
  z-index: 1;
}

.promo-kicker {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 2rpx;
}

.promo-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
}

.promo-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.45;
}

.promo-cta {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
}

.section-head {
  margin-top: 40rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.apt-head {
  margin-top: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}

.section-more {
  font-size: 24rpx;
  color: #0d9488;
  font-weight: 600;
}

.service-matrix {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.matrix-cell {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
  opacity: 0;
  transform: translateY(24rpx);
}

.matrix-in {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1), transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.matrix-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.matrix-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #334155;
  text-align: center;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.06);
  opacity: 0;
  transform: translateX(-20rpx);
}

.feature-in {
  opacity: 1;
  transform: translateX(0);
  transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f0fdfa, #ccfbf1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feature-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.feature-desc {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.4;
}

.feature-link {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #0d9488;
}

.apt-block {
  margin-top: 8rpx;
}

.apt-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
}

.apt-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #94a3b8;
}

.apt-dot.status-pending {
  background: #f59e0b;
}

.apt-dot.status-confirmed {
  background: #22c55e;
}

.apt-dot.status-completed {
  background: #0d9488;
}

.apt-dot.status-cancelled,
.apt-dot.status-expired,
.apt-dot.status-missed {
  background: #cbd5e1;
}

.apt-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.apt-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.apt-sub {
  font-size: 24rpx;
  color: #64748b;
}

.todo-card {
  margin-top: 28rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  border: 1rpx dashed rgba(13, 148, 136, 0.35);
}

.todo-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #ecfeff, #cffafe);
  display: flex;
  align-items: center;
  justify-content: center;
}

.todo-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #334155;
}

.todo-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.todo-login {
  margin-top: 28rpx;
  width: 100%;
  max-width: 420rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
}

.todo-login::after {
  border: none;
}

.home-safe-bottom {
  height: 32rpx;
}
