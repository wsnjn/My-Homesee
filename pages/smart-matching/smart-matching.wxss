.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #ecfeff 0%, #f0fdfa 40%, #f8fafc 100%);
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
}

.message-list {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.message {
  display: flex;
  gap: 14rpx;
  max-width: 88%;
}

.user-message {
  align-self: flex-end;
  flex-direction: row-reverse;
}

.ai-message {
  align-self: flex-start;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.message-content {
  flex: 1;
}

.message-bubble {
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}

.ai-message .message-bubble {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  color: #111827;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
}

.user-message .message-bubble {
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  color: #ffffff;
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(13, 148, 136, 0.28);
}

.rich-content {
  line-height: 1.6;
  word-break: break-word;
}

.ai-link {
  display: inline-flex;
  align-items: center;
  margin: 8rpx 8rpx 8rpx 0;
  padding: 10rpx 16rpx;
  background: #EFF6FF;
  border: 1rpx solid #BFDBFE;
  border-radius: 999rpx;
  max-width: 100%;
  box-sizing: border-box;
}

.ai-link:active {
  opacity: 0.85;
  background: #DBEAFE;
}

.ai-link-disabled {
  background: #F3F4F6;
  border-color: #E5E7EB;
  opacity: 0.9;
}

.ai-link-label {
  color: #2563EB;
  font-size: 24rpx;
}

.ai-link-disabled .ai-link-label {
  color: #6B7280;
  text-decoration: none;
}

.ai-link-reason {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-left: 6rpx;
}

.chat-input-area {
  background: rgba(255, 255, 255, 0.96);
  padding: 14rpx 20rpx calc(env(safe-area-inset-bottom) + 14rpx);
  border-top: 1rpx solid #E5E7EB;
}

.input-wrapper {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.chat-input {
  width: 70%;
  flex: 0 0 70%;
  height: 72rpx;
  background: #F8FAFC;
  border-radius: 36rpx;
  border: 1rpx solid #E5E7EB;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #111827;
}

.chat-input:focus {
  border-color: #111827;
}

.send-btn {
  width: 30%;
  flex: 0 0 30%;
  height: 72rpx;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  border: none !important;
}

.send-btn::after {
  border: none;
}

.send-btn.disabled {
  background: #E5E7EB !important;
  color: #9CA3AF;
}

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 30rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #6B7280;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { 
  animation-delay: -0.32s; 
}

.dot:nth-child(2) { 
  animation-delay: -0.16s; 
}

@keyframes bounce {
  0%, 80%, 100% { 
    transform: scale(0); 
    opacity: 0.5;
  }
  40% { 
    transform: scale(1); 
    opacity: 1;
  }
}

.ai-cards {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.ai-card {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 14rpx;
}

.ai-card-cover {
  width: 100%;
  height: 170rpx;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  background: #f1f5f9;
}

.ai-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.ai-card-title {
  font-size: 24rpx;
  color: #0f172a;
  font-weight: 700;
  flex: 1;
}

.ai-card-price {
  font-size: 24rpx;
  color: #0d9488;
  font-weight: 700;
}

.ai-card-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.ai-card-actions {
  margin-top: 10rpx;
  display: flex;
  gap: 10rpx;
}

.ai-card-btn {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  border-radius: 999rpx;
  padding: 8rpx 0;
}

.ai-card-btn.ghost {
  color: #0d9488;
  background: #ecfeff;
  border: 1rpx solid #99f6e4;
}
