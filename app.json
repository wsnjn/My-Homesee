{
  "pages": [
    "pages/login/login",
    "pages/legal/user-agreement",
    "pages/legal/privacy-policy",
    "pages/home/home",
    "pages/house-selection/house-selection",
    "pages/house-detail/house-detail",
    "pages/mine/mine",
    "pages/smart-matching/smart-matching",
    "pages/community/community",
    "pages/map-search/map-search"
  ],
  "subpackages": [
    {
      "root": "packageA",
      "name": "vr-tour",
      "pages": [
        "pages/house-tour/house-tour",
        "pages/interactive-cube/interactive-cube"
      ]
    },
    {
      "root": "packageB",
      "name": "tenant-services",
      "pages": [
        "pages/maintenance/maintenance",
        "pages/my-appointments/my-appointments",
        "pages/user-profile/user-profile",
        "pages/appointment/appointment",
        "pages/contract-center/contract-center",
        "pages/bill-center/bill-center",
        "pages/feedback-center/feedback-center",
        "pages/move-service/move-service",
        "pages/wifi-service/wifi-service"
      ]
    },
    {
      "root": "packageC",
      "name": "admin-management",
      "pages": [
        "pages/admin/admin",
        "pages/landlord/landlord",
        "pages/maintenance-list/maintenance-list"
      ]
    },
    {
      "root": "packageD",
      "name": "social",
      "pages": [
        "pages/friend-circle/friend-circle",
        "pages/chat-area/chat-area"
      ]
    }
  ],
  "preloadRule": {
    "pages/home/home": {
      "network": "all",
      "packages": [
        "tenant-services"
      ]
    },
    "pages/house-selection/house-selection": {
      "network": "all",
      "packages": [
        "vr-tour"
      ]
    },
    "pages/smart-matching/smart-matching": {
      "network": "all",
      "packages": [
        "social"
      ]
    }
  },
  "window": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "HOMESEE",
    "navigationBarBackgroundColor": "#0f766e",
    "backgroundColor": "#f0fdfa",
    "backgroundTextStyle": "dark",
    "enablePullDownRefresh": false
  },
  "tabBar": {
    "color": "#94a3b8",
    "selectedColor": "#0d9488",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/home",
        "text": "首页"
      },
      {
        "pagePath": "pages/house-selection/house-selection",
        "text": "看房"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的"
      }
    ]
  },
  "style": "v2",
  "usingComponents": {
    "svg-icon": "/components/svg-icon/svg-icon"
  },
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于推荐附近的房源"
    }
  },
  "requiredPrivateInfos": [
    "getLocation",
    "chooseLocation"
  ]
}